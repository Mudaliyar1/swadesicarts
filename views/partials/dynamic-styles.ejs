<style>
    /* Dynamic Theme Colors from Admin Settings */
    <% if (siteSettings && siteSettings.colors) { %>
        :root {
            /* Map admin settings to both legacy and new CSS variables */
            --swadesi-green: <%= siteSettings.colors.primary || '#4C1E4F' %>;
            --swadesi-accent: <%= siteSettings.colors.accent || '#B5A886' %>;
            --swadesi-light: #f8f9fa;
            --swadesi-dark: <%= siteSettings.colors.bodyText || '#2c3e50' %>;

            /* New style-new.css variables */
            --primary: <%= siteSettings.colors.primary || '#4C1E4F' %>;
            --primary-light: <%= siteSettings.colors.accent || '#B5A886' %>;
            --accent: <%= siteSettings.colors.accent || '#B5A886' %>;
            --secondary: <%= siteSettings.colors.secondary || '#6C8E7F' %>;
            --light: #f8f9fa;
            --dark: <%= siteSettings.colors.bodyText || '#1a1a1a' %>;
            --font-primary: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            --link-color: <%= siteSettings.colors.linkColor || '#B5A886' %>;
        }

        /* Compute site background: either gradient or solid color */
        <% if (siteSettings.colors.backgroundType === 'gradient' && siteSettings.colors.backgroundGradient && siteSettings.colors.backgroundGradient.trim().length > 0) { %>
            :root { --site-background: <%= siteSettings.colors.backgroundGradient %>; }
        <% } else if (siteSettings.colors.backgroundType === 'gradient') { %>
            /* build gradient from stored stops if provided (fallback) */
            :root { --site-background: linear-gradient(135deg, <%= siteSettings.colors.backgroundGradientStop1 || '#000000' %> 0%, <%= siteSettings.colors.backgroundGradientStop2 || '#444444' %> 100%); }
        <% } else { %>
            :root { --site-background: <%= siteSettings.colors.bodyBackgroundColor || '#ffffff' %>; }
        <% } %>

        body {
            background: var(--site-background) !important;
            background-image: none !important;
        }

        h1, h2, h3, h4, h5, h6 {
            color: <%= siteSettings.colors.headingText || '#2c3e50' %>;
        }

        body, p, span {
            color: <%= siteSettings.colors.bodyText || '#495057' %>;
        }

        a {
            color: <%= siteSettings.colors.linkColor || '#B5A886' %>;
        }

        .bg-swadesi {
            background-color: var(--primary) !important;
        }

        .text-swadesi {
            color: var(--primary) !important;
        }

        .text-accent {
            color: var(--accent) !important;
        }

        .border-swadesi {
            border-color: var(--primary) !important;
        }

        .btn-swadesi {
            background-color: var(--primary);
            border-color: var(--primary);
            color: white;
        }

        .btn-swadesi:hover {
            background-color: var(--primary);
            border-color: var(--primary);
            color: white;
            opacity: 0.9;
        }

        .btn-outline-swadesi {
            border-color: var(--primary);
            color: var(--primary);
        }

        .btn-outline-swadesi:hover {
            background-color: var(--primary);
            border-color: var(--primary);
            color: white;
        }

        /* Override navbar background (style-new.css used a gradient) */
        .navbar,
        .navbar.bg-swadesi {
            background: var(--primary) !important;
            background-image: none !important;
        }

        .navbar a {
            color: <%= siteSettings.colors.headerFooterLinkColor || '#FFD700' %> !important;
        }

        .navbar a:hover {
            color: <%= siteSettings.colors.headerFooterLinkColor || '#FFD700' %> !important;
            opacity: 0.8;
        }

        footer {
            background-color: var(--primary) !important;
        }

        footer a {
            color: <%= siteSettings.colors.headerFooterLinkColor || '#FFD700' %> !important;
        }

        footer a:hover {
            color: <%= siteSettings.colors.headerFooterLinkColor || '#FFD700' %> !important;
            opacity: 0.8;
        }

        /* Force hero and carousel backgrounds to use the site background so inline styles don't override admin setting */
        .hero-slide,
        .hero-carousel-section,
        #heroCarousel .carousel-item,
        .hero-pattern {
            background: var(--site-background) !important;
            background-image: none !important;
        }

        <% if (siteSettings.designEditor && Array.isArray(siteSettings.designEditor.rules) && siteSettings.designEditor.rules.length > 0) { %>
            <% siteSettings.designEditor.rules.forEach(function(rule) { %>
                <% if (rule && rule.selector && rule.styles) { %>
        <%- rule.selector %> {
                    <% if (rule.styles.textMode === 'gradient' && rule.styles.textGradientStart && rule.styles.textGradientEnd) { %>
                    background-image: linear-gradient(<%- rule.styles.textGradientDirection || '135deg' %>, <%- rule.styles.textGradientStart %>, <%- rule.styles.textGradientEnd %>) !important;
                    -webkit-background-clip: text !important;
                    background-clip: text !important;
                    color: transparent !important;
                    -webkit-text-fill-color: transparent !important;
                    <% } else if (rule.styles.color) { %>
                    color: <%- rule.styles.color %> !important;
                    <% } %>

                    <% if (rule.styles.backgroundMode === 'gradient' && rule.styles.backgroundGradientStart && rule.styles.backgroundGradientEnd) { %>
                    background-image: linear-gradient(<%- rule.styles.backgroundGradientDirection || '135deg' %>, <%- rule.styles.backgroundGradientStart %>, <%- rule.styles.backgroundGradientEnd %>) !important;
                    background-size: cover !important;
                    background-repeat: no-repeat !important;
                    background-position: center !important;
                    <% } else if (rule.styles.backgroundMode === 'color' && rule.styles.backgroundColor) { %>
                    background-color: <%- rule.styles.backgroundColor %> !important;
                    <% } %>

                    <% if (rule.styles.borderRadius) { %>border-radius: <%- rule.styles.borderRadius %> !important;<% } %>
                    <% if (rule.styles.fontSize) { %>font-size: <%- rule.styles.fontSize %> !important;<% } %>
                    <% if (rule.styles.fontFamily) { %>font-family: <%- rule.styles.fontFamily %> !important;<% } %>
                    <% if (rule.styles.fontWeight) { %>font-weight: <%- rule.styles.fontWeight %> !important;<% } %>
                    <% if (rule.styles.fontStyle) { %>font-style: <%- rule.styles.fontStyle %> !important;<% } %>
                    <% if (rule.styles.lineHeight) { %>line-height: <%- rule.styles.lineHeight %> !important;<% } %>
                    <% if (rule.styles.letterSpacing) { %>letter-spacing: <%- rule.styles.letterSpacing %> !important;<% } %>
        }
                <% } %>
            <% }); %>
        <% } %>
    <% } %>
</style>
